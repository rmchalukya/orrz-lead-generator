{
  "name": "orrz-lead-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx watch worker/index.ts",
    "worker:start": "tsx worker/index.ts",
    "start:worker": "tsx scripts/migrate-deploy.mts && tsx worker/index.ts",
    "migrate:deploy": "tsx scripts/migrate-deploy.mts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx --env-file=.env scripts/seed-templates.mts",
    "demo": "tsx --env-file=.env scripts/run-demo.mts",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@prisma/client": "^6.2.0",
    "cheerio": "^1.0.0",
    "next": "^15.1.0",
    "pg-boss": "^10.1.5",
    "prisma": "^6.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
