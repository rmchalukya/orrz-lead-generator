# --- Database ---
# Either set DATABASE_URL directly...
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"
# ...OR provide the parts and DATABASE_URL is assembled from them (see core/env.ts).
# DATABASE_URL, if set, always wins.
# INIT_COMMON_MASTER_HOST="host"
# INIT_COMMON_MASTER_PORT="5432"          # 42337 for Railway's public proxy
# INIT_COMMON_MASTER_USER="postgres"
# INIT_COMMON_MASTER_PASSWORD="..."
# INIT_COMMON_MASTER_DATABASE="railway"
# INIT_COMMON_MASTER_PARAMS="?connection_limit=5&pool_timeout=20"  # optional query string

# --- Queue (pg-boss runs on the same Postgres; no Redis needed) ---
# Defaults to DATABASE_URL if unset.
PGBOSS_DATABASE_URL=""

# --- Discovery: Google Places API (New) ---
GOOGLE_PLACES_API_KEY=""

# --- AI personalization: Anthropic (Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=""

# --- Outreach: Resend (email channel) ---
RESEND_API_KEY=""
# Format: "Display Name <email>". Requires a VERIFIED DOMAIN in Resend for real sending;
# until then use "Your Name <onboarding@resend.dev>" (delivers only to your own inbox).
RESEND_FROM="Your Name <onboarding@resend.dev>"
RESEND_WEBHOOK_SECRET=""

# Sender identity shown in email signatures.
SENDER_NAME="Your Name"
SENDER_COMPANY="Your Company"
SENDER_PHONE="+91 00000 00000"
# One or more comma-separated URLs; each renders as a clickable link in the signature.
SENDER_WEBSITE="https://yourcompany.com/"
# Optional comma-separated pool to rotate the sender name per lead (deterministic).
# Use REAL teammates' names only — a fake From identity is deceptive + anti-spam risk.
SENDER_NAME_POOL=""

# --- App ---
APP_BASE_URL="http://localhost:3000"
